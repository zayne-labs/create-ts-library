{
	"name": "root",
	"type": "module",
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "turbo run --filter=./packages/* build",
		"build:test": "turbo run --filter=./packages/* build:test",
		"bump": "bumpp",
		"dev:packages": "turbo run --filter=./packages/* dev",
		"inspect:eslint-config": "pnpx @eslint/config-inspector@latest",
		"lint:attw": "turbo run --filter=./packages/* lint:attw",
		"lint:eslint": "turbo run lint:eslint",
		"lint:eslint:interactive": "turbo run lint:eslint:interactive",
		"lint:eslint:root": "eslint . --max-warnings=0",
		"lint:eslint:root:interactive": "pnpx eslint-interactive@latest . --max-warnings=0 --fix",
		"lint:format": "turbo run lint:format",
		"lint:format:root": "prettier --write .",
		"lint:publint": "turbo run --filter=./packages/* lint:publint",
		"lint:size": "turbo run --filter=./packages/* lint:size",
		"lint:type-check": "turbo run --filter=./packages/* lint:type-check",
		"prepare": "husky",
		"release": "pnpm --filter=./packages/* release",
		"release:test": "pnpx pkg-pr-new publish './packages/*' --compact",
		"test": "turbo run --filter=./packages/* test",
		"test:browser": "turbo run --filter=./packages/* test:browser",
		"test:coverage": "turbo run --filter=./packages/* test:coverage",
		"test:dev": "turbo run --filter=./packages/* test:dev"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@eslint-react/eslint-plugin": "3.0.0",
		"@next/eslint-plugin-next": "^16.2.1",
		"@types/node": "^25.5.0",
		"@zayne-labs/eslint-config": "^0.12.4",
		"@zayne-labs/prettier-config": "^0.12.4",
		"@zayne-labs/tsconfig": "0.12.4",
		"bumpp": "^10.4.1",
		"eslint": "10.1.0",
		"eslint-plugin-better-tailwindcss": "4.3.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-react-you-might-not-need-an-effect": "0.9.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "3.8.1",
		"prettier-plugin-classnames": "0.10.1",
		"prettier-plugin-merge": "0.10.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"turbo": "^2.9.2",
		"typescript": "6.0.2"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	}
}

{
	"name": "[package-name]",
	"type": "module",
	"version": "0.0.0",
	"description": "[*]",
	"author": "Ryan Zayne",
	"license": "MIT",
	"homepage": "https://github.com/[*]/#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/[*].git"
	},
	"bugs": {
		"url": "https://github.com/[*]/issues"
	},
	"keywords": [],
	"sideEffects": false,
	"exports": {
		".": "./dist/esm/index.js"
	},
	"main": "./dist/esm/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/esm/index.d.ts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18.x"
	},
	"scripts": {
		"build": "tsup",
		"build:dev": "cross-env NODE_ENV=development tsup",
		"build:test": "concurrently --prefix-colors \"yellow.bold,#7da4f8.bold,magenta\" --names PUBLINT,TSUP 'pnpm:lint:publint' 'pnpm:build:dev'",
		"dev": "pnpm build:dev --watch",
		"lint:attw": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
		"lint:eslint": "eslint . --max-warnings=0",
		"lint:eslint:interactive": "pnpx eslint-interactive@latest . --max-warnings=0 --fix",
		"lint:format": "prettier --write .",
		"lint:publint": "publint --strict .",
		"lint:size": "size-limit",
		"lint:type-check": "tsc --pretty  -p tsconfig.json",
		"release": "pnpm publish --no-git-checks",
		"release:test": "pnpx pkg-pr-new publish"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.18.2",
		"@size-limit/esbuild-why": "12.0.1",
		"@size-limit/preset-small-lib": "12.0.1",
		"@total-typescript/ts-reset": "0.6.1",
		"@zayne-labs/tsconfig": "0.12.4",
		"concurrently": "9.2.1",
		"cross-env": "10.1.0",
		"publint": "0.3.18",
		"size-limit": "12.0.1",
		"tsdown": "^0.21.7",
		"typescript": "6.0.2"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"size-limit": [
		{
			"path": "./src/index.ts",
			"limit": "[*] kb"
		},
		{
			"path": "./src/[*]/index.ts",
			"limit": "[*] kb"
		}
	]
}
